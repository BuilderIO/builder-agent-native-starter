{
  "database": {
    "kind": "postgres",
    "migrations": "drizzle",
    "schemaDir": "drizzle"
  },
  "hosting": {
    "buildCommand": "pnpm run build",
    "buildOutputDir": "dist",
    "nodeVersion": "22",
    "environment": {
      "build": {
        "NITRO_PRESET": "netlify"
      },
      "prod": {
        "NODE_ENV": "production",
        "DISABLE_AUTH": true
      }
    }
  }
}
